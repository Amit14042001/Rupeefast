{
  "expo": {
    "name": "RupeeFast",
    "slug": "rupeefast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "rupeefast",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1E3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rupeefast.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "RupeeFast uses Face ID to secure your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1E3D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rupeefast.mobile",
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-dev-client"
    ]
  }
}
