# ── RupeeFast Mobile Environment ────────────────────
# Copy this file to .env and fill in your values.
# All Expo client env vars MUST be prefixed with EXPO_PUBLIC_

# ── Backend API URL ────────────────────────────────
# Android emulator: http://10.0.2.2:3000/api
# iOS simulator:    http://localhost:3000/api
# Physical device:  http://<your-lan-ip>:3000/api
# Production:       https://api.rupeefast.com/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ── Razorpay Payment Gateway ───────────────────────
# Get test keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for development, rzp_live_* for production
# EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Future Environment Variables ───────────────────
# Analytics
# EXPO_PUBLIC_AMPLITUDE_KEY=
# EXPO_PUBLIC_MIXPANEL_TOKEN=

# Feature Flags
# EXPO_PUBLIC_ENABLE_BIOMETRICS=true
# EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# Sentry (client-side error tracking)
# EXPO_PUBLIC_SENTRY_DSN=
