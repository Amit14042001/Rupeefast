[TEMPLATE]
# ── Production Mode ────────────────────────────
# Set to 'production' to enable production-only behaviors (e.g. crash on missing JWT_SECRET)
NODE_ENV=development

# ── PostgreSQL Connection ──────────────────────
# Option A: Connection string (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rupeefast
# Option B: Individual variables (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=rupeefast
PGUSER=postgres
PGPASSWORD=postgres

# Connection pool tuning
# PGPOOL_MAX=20
# PGPOOL_IDLE_TIMEOUT=30000
# PGPOOL_CONNECT_TIMEOUT=5000

# ── Redis Connection (Session Cache, Rate Limiting) ──
# Option A: Connection string (recommended)
REDIS_URL=redis://localhost:6379
# Option B: Individual variables (used if REDIS_URL is not set)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# Key prefix for all Redis keys (useful when sharing a Redis instance)
# REDIS_KEY_PREFIX=rf:

# Cache TTL values (seconds)
# DASHBOARD_CACHE_TTL=300    # Cache dashboard data for 5 minutes
# RATE_LIMIT_CACHE_TTL=60    # Rate limit window (matches GENERAL_RATE_LIMIT window)

# ── JWT Authentication ────────────────────────
# ⚠️  CHANGE THIS IN PRODUCTION! Use a strong, random string.
#     In production mode, server will crash on startup if this is missing or default.
JWT_SECRET=rupeefast-dev-secret-change-in-production

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Razorpay Payment Gateway ───────────────────
# Get live keys from https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
# RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── KYC Provider ──────────────────────────────
# Integration with Digilocker / Signzy / HyperVerge for Aadhaar & PAN verification
# KYC_PROVIDER=digilocker    # digilocker | signzy | hyperverge | mock
# KYC_API_KEY=your_kyc_api_key
# KYC_API_SECRET=your_kyc_api_secret

# ── Credit Bureau (CIBIL / NPCL / Experian) ───
# CIBIL_API_ENABLED=false      # Set to 'true' when bureau integration is active
# CIBIL_API_KEY=your_cibil_api_key
# CIBIL_API_SECRET=your_cibil_api_secret
# CIBIL_API_BASE_URL=https://api.cibil.com/v1

# ── Loan Disbursement ─────────────────────────
# DISBURSEMENT_MODE=internal     # internal | razorpay_payout | cashfree
# DISBURSEMENT_AUTO_APPROVE=true # Auto-approve loans under this threshold
# DISBURSEMENT_MAX_AUTO_AMOUNT=10000

# ── Android Signing ──────────────────────────
# KEYSTORE_PASSWORD=your_keystore_password
# KEY_ALIAS=your_key_alias
# KEY_PASSWORD=your_key_password

# ── Feature Flags ────────────────────────────
# AUTO_VERIFY_KYC=false    # Auto-verify KYC in development; set false in production
# DEMO_MODE=true           # Enable demo/mock data for frontend development

# ── Sentry Error Tracking ────────────────────
# Get DSN from https://sentry.io/settings/.../projects/.../keys/
# SENTRY_DSN=https://xxx@o1.ingest.sentry.io/1234567
# SENTRY_ENVIRONMENT=production           # Default: NODE_ENV value
# SENTRY_TRACES_SAMPLE_RATE=0.1           # % of requests to trace (0.0 - 1.0, default 0.1)
# SENTRY_PROFILES_SAMPLE_RATE=0.05        # % of traces to profile (0.0 - 1.0, default disabled)

# ── Metrics ─────────────────────────────────
# Prometheus metrics endpoint at /api/metrics. Enabled by default.
# METRICS_ENABLED=false    # Disable to reduce overhead on very small instances

# ── Logging ──────────────────────────────────
# LOG_LEVEL=info       # debug | info | warn | error (default: info in prod, debug in dev)
# LOG_SHIP_ADDRESS=logs.papertrailapp.com  # Hostname or IP of the remote log aggregator
# LOG_SHIP_PORT=12345                      # Port of the remote log aggregator
# LOG_SHIP_MODE=tcp    # tcp (default) or udp

# ── Rate Limiting ─────────────────────────────
# Requests per window. Tune based on expected traffic.
# LOGIN_RATE_LIMIT=5    # per 15 minutes (only failed attempts count toward limit)
# GENERAL_RATE_LIMIT=60  # per minute
# PAYMENT_RATE_LIMIT=10  # per minute
